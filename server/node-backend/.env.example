# Node.js Backend Environment Variables
# Copy this file to .env and fill in the values

# Database Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Redis (Optional — for socket state durability + horizontal scaling)
REDIS_URL=redis://localhost:6379

# Security Keys (Generate strong random strings)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
TWO_FACTOR_ENCRYPTION_KEY=your-encryption-key-for-2fa-min-32-chars

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Python Backend URL
PYTHON_SERVICE_URL=http://localhost:5001

# Email Configuration (for password reset, contact form)
SMTP_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL="In-Aspired" <noreply@in-aspired.com>

# Official email 
OFFICIAL_EMAIL=inaspired.official@gmail.com

# Google Gemini API Key (Get from: https://aistudio.google.com/app/apikey) for chatbot
GEMINI_API_KEY=AIzaSy...your-key-here

# Push notifications
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=inaspired.official@gmail.com

# Lemon Squeezy (Payment)
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_VARIANT_ID=your-variant-id
LEMONSQUEEZY_API_KEY=your-api-key
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret