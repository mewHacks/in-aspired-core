{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "outDir": "./dist",
    "rootDirs":  ["./src", "../../shared/src"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ],
    "baseUrl": ".",
    "paths": {
      "@in-aspired/shared": [
        "../../shared/src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*",
    "../../shared/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}