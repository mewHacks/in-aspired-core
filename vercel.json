{
    "buildCommand": "cd shared && npm run build && cd ../client && npm run build",
    "outputDirectory": "client/dist",
    "installCommand": "npm install",
    "framework": null,
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://in-aspired-backend.fly.dev/api/:path*"
        },
        {
            "source": "/socket.io/:path*",
            "destination": "https://in-aspired-backend.fly.dev/socket.io/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}